{
  "name": "scanic",
  "version": "1.2.0",
  "description": "Modern document scanner in pure JavaScript and Wasm",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/scanic.umd.cjs",
  "module": "dist/scanic.js",
  "types": "src/scanic.d.ts",
  "exports": {
    ".": {
      "types": "./src/scanic.d.ts",
      "import": "./dist/scanic.js",
      "require": "./dist/scanic.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:gh-pages": "vite build && node scripts/post-build.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vite build && node scripts/stage-docs-demo.mjs && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint src scripts",
    "build:wasm": "docker compose -f dev/docker-compose.yml up --build && node scripts/postprocess-wasm.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "diagnose:quality": "node scripts/diagnose-quality.js",
    "baseline:update": "node scripts/baseline.js --update",
    "baseline:check": "node scripts/baseline.js",
    "test:watch": "vitest",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "release": "node scripts/release.js"
  },
  "keywords": [
    "document",
    "scanner",
    "image",
    "processing",
    "contour",
    "detection"
  ],
  "author": "marquaye",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marquaye/scanic.git"
  },
  "homepage": "https://marquaye.github.io/scanic",
  "bugs": {
    "url": "https://github.com/marquaye/scanic/issues"
  },
  "files": [
    "dist/scanic.js",
    "dist/scanic.umd.cjs",
    "src/scanic.d.ts",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "canvas": "^3.2.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "terser": "^5.44.1",
    "vite": "^8.0.16",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.16",
    "vue": "^3.5.38"
  }
}
